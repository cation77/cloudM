generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                   String                 @id @default(nanoid(12))
  name                 String
  description          String
  defaultModelConfigId String?
  test                 String                 @default("")
  createAt             DateTime               @default(now())
  updateAt             DateTime               @updatedAt
}